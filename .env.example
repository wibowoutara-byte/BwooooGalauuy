# ─────────────────────────────────────────────────────────────
# WA Checker Bot — Konfigurasi
# Salin file ini menjadi .env lalu isi nilainya.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# WAJIB: Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPSIONAL: Nomor WA default untuk /pair (format 628xxx, tanpa + atau 0)
OWNER_PHONE_NUMBER=6281234567890

# OPSIONAL: User ID Telegram admin (dapat /admin, /broadcast, dll)
# Cari ID kamu via @userinfobot
ADMIN_USER_ID=123456789

# OPSIONAL: Daftar user yang diizinkan (pisah koma).
# Kosongkan = semua orang bisa pakai (mode terbuka).
ALLOWED_USER_IDS=

# OPSIONAL: Batas & rate limit
MAX_NUMBERS_PER_REQUEST=50
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQ=5
NODE_CHECK_TIMEOUT_SEC=180
